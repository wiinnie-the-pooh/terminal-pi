{
  "name": "pi-dock",
  "displayName": "Pi Dock",
  "description": "Pi Agent Docked in the VS Code Editor Area",
  "version": "0.2.26",
  "publisher": "wiinnie-the-pooh",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/wiinnie-the-pooh/terminal-pi.git"
  },
  "bugs": {
    "url": "https://github.com/wiinnie-the-pooh/terminal-pi/issues"
  },
  "homepage": "https://github.com/wiinnie-the-pooh/terminal-pi#readme",
  "icon": "resources/icons/pi-dock.png",
  "galleryBanner": {
    "color": "#1e1e1e",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.94.0"
  },
  "categories": [
    "AI",
    "Other"
  ],
  "keywords": [
    "pi",
    "ai",
    "agent",
    "coding",
    "terminal"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "piDock.run",
        "title": "Run Pi Dock",
        "category": "Pi Dock",
        "icon": {
          "light": "resources/icons/pi-light.svg",
          "dark": "resources/icons/pi-dark.svg"
        }
      },
      {
        "command": "piDock.runWithSkill",
        "title": "Run Pi with Skill...",
        "category": "Pi Dock"
      },
      {
        "command": "piDock.runWithTemplate",
        "title": "Run Pi with Template...",
        "category": "Pi Dock"
      },
      {
        "command": "piDock.runWithExtension",
        "title": "Run Pi with Extension...",
        "category": "Pi Dock"
      }
    ],
    "configuration": {
      "title": "Pi Dock",
      "properties": {
        "piDock.defaultArgs": {
          "type": "string",
          "order": 1,
          "default": "",
          "description": "Default arguments to pass to the pi CLI on every invocation (e.g. '--model openai/gpt-4o --thinking low')."
        },
        "piDock.editorCommand": {
          "type": "string",
          "order": 2,
          "default": "",
          "description": "Command exported as EDITOR and VISUAL in Pi terminals. Leave empty to auto-detect the current desktop editor CLI (VS Code, VS Code Insiders, or Cursor). If detection fails, Pi Dock preserves existing VISUAL/EDITOR values and otherwise lets pi use its own fallback behavior."
        },
        "piDock.virtualEnvironmentOverride": {
          "type": "boolean",
          "order": 4,
          "default": true,
          "description": "When true, the extension briefly disables Python terminal environment activation while creating a Pi terminal, preventing virtual-environment activation text from being injected into pi. Set to false to disable this workaround."
        },
        "piDock.virtualEnvironmentDrainMs": {
          "type": "number",
          "order": 5,
          "default": 150,
          "minimum": 0,
          "maximum": 10000,
          "description": "Milliseconds to wait after creating a Pi terminal before restoring 'python.terminal.activateEnvironment'. The delay lets the Python extension's onDidOpenTerminal handler observe the temporarily-disabled value so it skips injecting venv activation commands. Ignored when 'piDock.virtualEnvironmentOverride' is false. Set to 0 to restore immediately (may race with the Python extension)."
        }
      }
    },
    "menus": {
      "editor/title": [
        {
          "command": "piDock.run",
          "group": "navigation@-1"
        }
      ],
      "explorer/context": [
        {
          "command": "piDock.runWithSkill",
          "when": "resourceScheme == file && resourceFilename == SKILL.md",
          "group": "navigation"
        },
        {
          "command": "piDock.runWithTemplate",
          "when": "resourceScheme == file && resourceExtname == .md && resourceFilename != SKILL.md",
          "group": "navigation"
        },
        {
          "command": "piDock.runWithExtension",
          "when": "resourceScheme == file && resourceExtname == .ts",
          "group": "navigation"
        }
      ],
      "editor/context": [
        {
          "command": "piDock.runWithSkill",
          "when": "resourceScheme == file && resourceFilename == SKILL.md",
          "group": "navigation"
        },
        {
          "command": "piDock.runWithTemplate",
          "when": "resourceScheme == file && resourceExtname == .md && resourceFilename != SKILL.md",
          "group": "navigation"
        },
        {
          "command": "piDock.runWithExtension",
          "when": "resourceScheme == file && resourceExtname == .ts",
          "group": "navigation"
        }
      ]
    },
    "keybindings": [
      {
        "command": "workbench.action.terminal.sendSequence",
        "key": "ctrl+g",
        "when": "terminalFocus && piDock.activeTerminal",
        "args": {
          "text": "\u0007"
        }
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test tests/*.test.js",
    "watch": "tsc -watch -p ./",
    "package": "vsce package",
    "lint": "eslint src --ext ts"
  },
  "devDependencies": {
    "@types/node": "^20.19.39",
    "@types/vscode": "^1.94.0",
    "@vscode/vsce": "^3.0.0",
    "typescript": "^5.6.0"
  }
}
